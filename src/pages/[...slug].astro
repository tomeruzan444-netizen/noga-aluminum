---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Faq from '../components/Faq.astro';
import ContactForm from '../components/ContactForm.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import Toc from '../components/Toc.astro';
import { site, telLink, waLink } from '../data/site.js';
import { getHero } from '../data/groups.js';
import lastmod from '../data/lastmod.json';
import { buildToc } from '../lib/toc.js';
import Icon from '../components/Icons.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../content/pages/*.json', { eager: true });
  return Object.values(modules).map((m) => {
    const page = m.default;
    const slug = page.route === '/' ? undefined : page.route.replace(/^\/|\/$/g, '');
    return { params: { slug }, props: { page } };
  });
}

const { page } = Astro.props;
const isHome = page.route === '/';
const { html: contentHtml, toc } = buildToc(page.contentHtml);

// Per-category hero image (falls back to the team photo + its responsive srcset).
const heroData = getHero(page.route);
const heroSrc = heroData ? heroData.src : site.teamPhoto;
const heroSrcset = heroData ? undefined : site.teamPhotoSrcset;
const heroW = heroData ? heroData.w : 1597;
const heroH = heroData ? heroData.h : 850;
const heroAlt = heroData ? page.h1 : `הצוות המקצועי של ${site.name}`;

// "Updated <month year>" freshness/trust line, from the captured lastmod data.
const HEB_MONTHS = ['ינואר', 'פברואר', 'מרץ', 'אפריל', 'מאי', 'יוני', 'יולי', 'אוגוסט', 'ספטמבר', 'אוקטובר', 'נובמבר', 'דצמבר'];
const lm = lastmod[page.route];
let updated = null;
if (lm) { const [y, m] = lm.slice(0, 7).split('-'); updated = `${HEB_MONTHS[+m - 1]} ${y}`; }
---
<BaseLayout
  title={page.metaTitle}
  description={page.metaDesc}
  route={page.route}
  h1={page.h1}
  faq={page.faq}
  robots={page.robots}
  heroImage={heroSrc}
  heroSrcset={heroSrcset}
>
  <section class="page-hero">
    <img class="hero-bg" src={heroSrc} srcset={heroSrcset} sizes={heroSrcset ? site.teamPhotoSizes : undefined}
         alt={heroAlt} width={heroW} height={heroH}
         fetchpriority="high" loading="eager" decoding="async" />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container">
      <nav class="breadcrumb" aria-label="פירורי לחם">
        <a href="/">דף הבית</a>
        {!isHome && <><span>›</span><span aria-current="page">{page.h1}</span></>}
      </nav>
      <div class="hero-head">
        <h1>{page.h1}</h1>
        <p class="sub">{site.tagline}</p>
      </div>
      <div class="hero-form-card">
        <div class="hero-form-title">קבלו הצעת מחיר - השאירו פרטים</div>
        <ContactForm variant="hero" />
      </div>
    </div>
  </section>

  <div class="container">
    <div class="layout">
      <article class="content">
        {isHome && <ServicesGrid />}
        {!isHome && updated && <p class="updated">עודכן ב{updated}</p>}
        {!isHome && <Toc items={toc} />}
        <Fragment set:html={contentHtml} />
        <Faq items={page.faq} />
        <div class="cta-band">
          <h2>צריכים הצעת מחיר?</h2>
          <p>צרו קשר עוד היום - ייעוץ מקצועי והצעת מחיר משתלמת, ללא התחייבות.</p>
          <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
            <a class="btn btn-primary" href={telLink}><Icon name="phone" width="18" height="18" /> {site.phone}</a>
            <a class="btn btn-wa" href={waLink} target="_blank" rel="noopener"><Icon name="whatsapp" width="18" height="18" /> וואטסאפ</a>
          </div>
        </div>
      </article>
      <Sidebar />
    </div>
  </div>
</BaseLayout>
