---
import { site, mainNav, telLink } from '../data/site.js';
import Icon from './Icons.astro';
const here = Astro.url.pathname;
const isActive = (href) => href && (here === href || decodeURIComponent(here) === href);
const childActive = (item) => item.children?.some((c) => isActive(c.href));
---
<!-- Slim utility bar (desktop): scrolls away, only the main nav stays sticky -->
<div class="topbar">
  <div class="container">
    <div class="topbar-info">
      <span><Icon name="pin" width="14" height="14" /> פריסה ארצית · שירות מקצועי משנת {site.founded}</span>
    </div>
    <div class="topbar-contact">
      <span><Icon name="clock" width="14" height="14" /> א׳-ה׳ 09:00-18:30</span>
      <a href={`mailto:${site.email}`}><Icon name="mail" width="14" height="14" /> {site.email}</a>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="container">
    <a href="/" class="brand" aria-label={site.name}>
      <img src={site.logo} alt={site.name} width="150" height="46" />
    </a>
    <button class="nav-toggle" aria-label="תפריט" aria-expanded="false" aria-controls="main-nav">
      <span></span>
    </button>
    <nav class="main-nav" id="main-nav" aria-label="ניווט ראשי">
      <ul class="nav-list">
        {mainNav.map((item) => (
          item.children ? (
            <li class:list={['nav-item', 'has-children', { active: isActive(item.href) || childActive(item) }]}>
              {item.href ? (
                <a href={item.href} class="nav-link">{item.label}<span class="caret" aria-hidden="true"></span></a>
              ) : (
                <button type="button" class="nav-link nav-parent" aria-expanded="false">{item.label}<span class="caret" aria-hidden="true"></span></button>
              )}
              <button type="button" class="submenu-toggle" aria-label={`פתיחת תת-תפריט ${item.label}`} aria-expanded="false"></button>
              <ul class:list={['submenu', { wide: item.children.length > 6 }]}>
                {item.children.map((c) => (
                  <li><a href={c.href} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li class="nav-item">
              <a href={item.href} class="nav-link" aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
            </li>
          )
        ))}
      </ul>
      <a class="header-cta" href={telLink}>
        <Icon name="phone" width="18" height="18" /> <span>{site.phone}</span>
      </a>
    </nav>
  </div>
</header>
<script>
  const header = document.querySelector('.site-header');
  const btn = header.querySelector('.nav-toggle');
  const nav = document.getElementById('main-nav');
  btn?.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    document.body.classList.toggle('nav-open', open);
  });
  // Mobile: expand/collapse submenus
  header.querySelectorAll('.submenu-toggle, .nav-parent').forEach((t) => {
    t.addEventListener('click', (e) => {
      if (window.innerWidth > 980) return;
      e.preventDefault();
      const li = t.closest('.has-children');
      const open = li.classList.toggle('sub-open');
      t.setAttribute('aria-expanded', String(open));
    });
  });
  // Subtle elevation once the page is scrolled (passive, near-zero cost)
  const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  addEventListener('scroll', onScroll, { passive: true });
</script>
