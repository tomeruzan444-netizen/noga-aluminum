---
import { site, footerNav, telLink, waLink } from '../data/site.js';
import Icon from './Icons.astro';
const year = 2026;
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-about">
        <img src={site.logo} alt={site.name} width="150" height="44" loading="lazy" />
        <p>{site.name} - מומחים בכל עבודות האלומיניום בפריסה ארצית משנת {site.founded}: מעקות, גדרות, פרגולות, תריסים, סגירות חורף, תיקון חלונות וריתוך אלומיניום.</p>
        <ul class="footer-contact">
          <li><Icon name="clock" width="18" height="18" /> <span>{site.hours}</span></li>
          <li><Icon name="mail" width="18" height="18" /> <a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><Icon name="phone" width="18" height="18" /> <a href={telLink}>{site.phone}</a></li>
          <li><Icon name="whatsapp" width="18" height="18" /> <a href={waLink} target="_blank" rel="noopener">וואטסאפ</a></li>
        </ul>
      </div>
      <nav class="footer-links" aria-label="ניווט תחתון">
        {footerNav.map((col) => (
          <div class="footer-col">
            <h4>{col.title}</h4>
            <ul>{col.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
          </div>
        ))}
      </nav>
    </div>
    <div class="footer-bottom">© {year} {site.name}. כל הזכויות שמורות.</div>
  </div>
</footer>
