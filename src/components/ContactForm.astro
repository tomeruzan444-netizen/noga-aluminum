---
const { variant = 'default' } = Astro.props;
const isHero = variant === 'hero';
---
<form class:list={['contact-form', variant]} action="/contact.php" method="post">
  <input type="text" name="name" placeholder="שם מלא" aria-label="שם מלא" required autocomplete="name" />
  <input type="tel" name="phone" placeholder="טלפון" aria-label="מספר טלפון" required autocomplete="tel" inputmode="tel" />
  <input class="full" type="text" name="city" placeholder="מאיפה אתם?" aria-label="עיר או אזור מגורים" autocomplete="address-level2" />
  <textarea class="full" name="message" placeholder="איך אנחנו יכולים לעזור?" aria-label="פירוט הפנייה" rows={isHero ? 2 : 3}></textarea>
  <!-- honeypot for spam (visually-hidden, no layout overflow) -->
  <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
    style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);border:0;white-space:nowrap" />
  <input type="hidden" name="page" value={Astro.url.pathname} />
  <button type="submit" class="btn btn-primary btn-block full">שליחת פנייה</button>
  <p class="form-note full">פנייתכם תגיע ישירות אלינו ונחזור אליכם בהקדם.</p>
  <div class="form-success full" hidden role="status">
    <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M8 12.5l3 3 5-6"></path></svg>
    <strong>הפנייה נשלחה בהצלחה!</strong>
    <span>קיבלנו את פנייתכם ונחזור אליכם בהקדם. תודה 🙂</span>
  </div>
  <div class="form-error full" hidden role="alert">אירעה תקלה בשליחה. נסו שוב, או חייגו אלינו ישירות.</div>
</form>
<script>
  document.querySelectorAll('form.contact-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const ok = form.querySelector('.form-success');
      const err = form.querySelector('.form-error');
      err.hidden = true;
      const label = btn.textContent;
      btn.disabled = true; btn.textContent = 'שולח...';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error();
        // success: hide the inputs/button/note, reveal the confirmation
        form.querySelectorAll('input:not([type=hidden]), textarea, button, .form-note').forEach((el) => { el.style.display = 'none'; });
        ok.hidden = false;
        ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch {
        btn.disabled = false; btn.textContent = label;
        err.hidden = false;
      }
    });
  });
</script>
